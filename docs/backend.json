
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Extended information about the user, including their fitness profile and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique Firebase Auth ID." },
        "displayName": { "type": "string", "description": "The user's full name." },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string", "description": "Profile picture URL." },
        "bio": { "type": "string" },
        "fitnessLevel": { "type": "string", "enum": ["beginner", "intermediate", "advanced"] },
        "weightKg": { "type": "number" },
        "heightCm": { "type": "number" },
        "onboardingComplete": { "type": "boolean" }
      },
      "required": ["uid", "email"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    }
  }
}
